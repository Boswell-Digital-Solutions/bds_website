# Local development configuration — copy to `.env` (gitignored) and fill in.
# Bun loads `.env` automatically. In production (Render), set these in the
# service's environment instead; render.yaml declares them with sync: false.

# Where the server listens. Render injects PORT automatically and requires
# HOST 0.0.0.0. Set HOST=127.0.0.1 locally to keep the dev server off the LAN.
PORT=3000
HOST=0.0.0.0

# ForgeCustomer API base URL, e.g. https://api.forgecustomer.example
# Server-side only — never exposed to the browser. When unset, the BFF
# responds 503 INTEGRATION_UNCONFIGURED and the static site still works.
FORGECUSTOMER_API_BASE=

# Supabase project used for login. These two values are public by design and
# are served to the browser via /api/public-config. The service-role key must
# NEVER appear here or anywhere in this repo. SUPABASE_URL + SUPABASE_ANON_KEY
# also back the HUD support threads (server/hud.ts) once
# db/migrations/0001_hud_threads.sql is applied.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: pin the Supabase host the HUD BFF may reach (defense in depth). When
# unset, SUPABASE_URL's host is trusted as-is.
SUPABASE_ALLOWED_HOSTS=
